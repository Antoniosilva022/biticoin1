# Exemplo de arquivo .env
# Copie para .env e preencha com suas chaves

# RPC URLs (obtenha de Infura, Alchemy, etc.)
SEPOLIA_RPC_URL=https://sepolia.infura.io/v3/YOUR_PROJECT_ID
MAINNET_RPC_URL=https://mainnet.infura.io/v3/YOUR_PROJECT_ID

# Chave privada do deployer (NUNCA compartilhe!)
PRIVATE_KEY=0xSUA_CHAVE_PRIVADA

# Endereço da carteira que receberá 90% dos tokens
RECIPIENT_ADDRESS=0xEnderecoDestino

# Endereço do contrato após deploy
TOKEN_ADDRESS=0xEnderecoDoContrato

# API key do Etherscan para verificar o contrato (obter em etherscan.io/myapikey)
ETHERSCAN_API_KEY=SUA_CHAVE_ETHERSCAN

# Liquidez Uniswap V2
LIQUIDITY_BITI_AMOUNT=700000000
LIQUIDITY_ETH_AMOUNT=0.04