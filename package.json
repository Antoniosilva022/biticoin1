{
  "name": "biticoin-token",
  "version": "1.0.0",
  "description": "Biticoin ERC-20 Token - Criptomoeda baseada em conceitos do Bitcoin",
  "main": "index.js",
  "scripts": {
    "compile": "npx hardhat compile",
    "test": "npx hardhat test",
    "wallet:new": "npx hardhat run scripts/utils/generate-wallet.js",
    "balance:sepolia": "npx hardhat run scripts/utils/check-balance.js",
    "balance:mainnet": "npx hardhat run scripts/utils/check-balance.js --network mainnet",
    "balance:amoy": "npx hardhat run scripts/utils/check-balance.js --network polygonAmoy",
    "deploy:local": "npx hardhat run scripts/deploy/deploy-local.js",
    "deploy:sepolia": "npx hardhat run scripts/deploy/deploy-sepolia.js --network sepolia",
    "deploy:mainnet": "npx hardhat run scripts/deploy/deploy-mainnet.js --network mainnet",
    "deploy:amoy": "npx hardhat run scripts/deploy/deploy-amoy.js --network polygonAmoy",
    "deploy:polygon": "npx hardhat run scripts/deploy/deploy-polygon.js --network polygon",
    "balance:polygon": "npx hardhat run scripts/utils/check-balance.js --network polygon",
    "transfer:90:amoy": "npx hardhat run scripts/utils/send-90-percent.js --network polygonAmoy",
    "transfer:90:polygon": "npx hardhat run scripts/utils/send-90-percent.js --network polygon",
    "verify:amoy": "npx hardhat run scripts/utils/verify.js --network polygonAmoy",
    "verify:polygon": "npx hardhat run scripts/utils/verify.js --network polygon",
    "pool:polygon": "npx hardhat run scripts/utils/create-pool-v3.js --network polygon",
    "transfer:position": "npx hardhat run scripts/utils/transfer-position.js --network polygon",
    "transfer:90": "npx hardhat run scripts/utils/send-90-percent.js --network sepolia",
    "transfer:90:main": "npx hardhat run scripts/utils/send-90-percent.js --network mainnet",
    "verify:sepolia": "npx hardhat run scripts/utils/verify.js --network sepolia",
    "verify:mainnet": "npx hardhat run scripts/utils/verify.js --network mainnet",
    "info:sepolia": "npx hardhat run scripts/utils/info.js --network sepolia",
    "info:mainnet": "npx hardhat run scripts/utils/info.js --network mainnet",
    "test:transfer": "npx hardhat run scripts/utils/test-transfer-90.js",
    "launch:sepolia": "npx hardhat run scripts/deploy/deploy-and-transfer.js --network sepolia",
    "launch:mainnet": "npx hardhat run scripts/deploy/deploy-and-transfer.js --network mainnet",
    "launch:mainnet:auto": "npx hardhat run scripts/deploy/launch-mainnet.js --network mainnet",
    "launch:sepolia:auto": "npx hardhat run scripts/deploy/launch-sepolia.js --network sepolia",
    "liquidity:sepolia": "npx hardhat run scripts/utils/add-liquidity.js --network sepolia",
    "liquidity:mainnet": "npx hardhat run scripts/utils/add-liquidity.js --network mainnet"
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-chai-matchers": "^2.1.2",
    "@nomicfoundation/hardhat-ethers": "^3.1.3",
    "@nomicfoundation/hardhat-verify": "^2.1.3",
    "chai": "^4.5.0",
    "ethers": "^6.16.0",
    "hardhat": "^2.28.6",
    "sharp": "^0.34.5"
  },
  "dependencies": {
    "@openzeppelin/contracts": "^5.0.0",
    "dotenv": "^16.0.0"
  },
  "type": "module"
}
